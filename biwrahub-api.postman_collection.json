		{
			"name": "Batching",
			"item": [
				{
					"name": "Get options (ships + schedules)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.ships.length > 0) {",
									"        pm.collectionVariables.set('ship_uuid', json.ships[0].uuid);",
									"    }",
									"    if (json.schedules.length > 0) {",
									"        pm.collectionVariables.set('schedule_uuid', json.schedules[0].uuid);",
									"    }",
									"    console.log('Options loaded');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/biwrahub/options",
							"host": ["{{base_url}}"],
							"path": ["biwrahub", "options"]
						}
					}
				},
