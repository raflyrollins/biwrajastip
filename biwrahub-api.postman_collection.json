								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bag_codes\": [\"{{bag_code}}\"],\n  \"ship_id\": \"{{ship_uuid}}\",\n  \"schedule_id\": \"{{schedule_uuid}}\",\n  \"departure_date\": \"2026-07-20\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/biwrahub/batching",
							"host": ["{{base_url}}"],
							"path": ["biwrahub", "batching"]
						}
					}
				}
			]
		},
