									"    pm.expect(jsonData.bag).to.have.property('code');",
									"});",
									"var jsonData = pm.response.json();",
									"if (jsonData.bag) {",
									"    pm.collectionVariables.set('bag_code', jsonData.bag.code);",
									"    console.log('Bag: ' + jsonData.bag.code);",
									"    console.log('Packages: ' + jsonData.bag.total_packages);",
									"}"
								],
