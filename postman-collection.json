{
	"info": {
		"name": "BiwraJastip - Bagging & Batch API",
		"description": "API collection untuk testing fitur Bagging, Batch, dan Terima Paket.\n\nAlur:\n1. Login sebagai Staff (auth > 1. Login)\n2. Terima Paket: scan sender_tracking_number (no resi toko) → status jadi collected\n3. Buat Bag: scan tracking_code (code BiwraJastip) → status jadi bagging\n4. Buat Batch: scan kode Bag → assign bag ke batch",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "bag_code",
			"value": "",
			"type": "string"
		},
		{
			"key": "batch_code",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "1. Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (pm.response.code === 200 && jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    pm.test('Login berhasil', function () {",
									"        pm.expect(jsonData.token).to.be.a('string');",
									"        pm.expect(jsonData.user).to.have.property('role');",
									"    });",
									"    console.log('Token tersimpan: ' + jsonData.token.substring(0, 30) + '...');",
									"    console.log('User: ' + jsonData.user.name + ' (' + jsonData.user.role + ')');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"staff.sby@biwrajastip.com\",\n  \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "login"]
						}
					},
					"response": []
				},
				{
					"name": "2. Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Logout berhasil', function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.eql('Berhasil logout.');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "logout"]
						}
					},
					"response": []
				}
			]
		},
