{
    "$schema": "https://opencode.ai/config.json",
    "attachment": {
        "image": {
            "auto_resize": true,
            "max_width": 2000,
            "max_height": 2000,
            "max_base64_bytes": 5242880
        }
    },
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": ["php", "artisan", "boost:mcp"]
        }
    }
}
